  <diagram id="state" name="09 - Crop Lifecycle State Diagram">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="st1" value="Crop Lifecycle State Diagram" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=24;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="420" height="30" as="geometry" /></mxCell>
        <mxCell id="start" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1"><mxGeometry x="90" y="260" width="30" height="30" as="geometry" /></mxCell>
        <mxCell id="sPlanned" value="Planned" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="180" y="230" width="160" height="90" as="geometry" /></mxCell>
        <mxCell id="sPlanted" value="Planted" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="430" y="230" width="160" height="90" as="geometry" /></mxCell>
        <mxCell id="sGrowing" value="Growing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="690" y="230" width="160" height="90" as="geometry" /></mxCell>
        <mxCell id="sReady" value="Ready for Harvest" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="960" y="230" width="190" height="90" as="geometry" /></mxCell>
        <mxCell id="sHarvested" value="Harvested" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1260" y="230" width="170" height="90" as="geometry" /></mxCell>
        <mxCell id="sFailed" value="Failed / Lost" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="700" y="470" width="170" height="90" as="geometry" /></mxCell>
        <mxCell id="end" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;strokeWidth=3;" vertex="1" parent="1"><mxGeometry x="1540" y="255" width="34" height="34" as="geometry" /></mxCell>
        <mxCell id="se1" value="create crop" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;" edge="1" parent="1" source="start" target="sPlanned"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se2" value="confirm planting" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;" edge="1" parent="1" source="sPlanned" target="sPlanted"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se3" value="growth starts" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;" edge="1" parent="1" source="sPlanted" target="sGrowing"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se4" value="maturity reached" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;" edge="1" parent="1" source="sGrowing" target="sReady"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se5" value="harvest recorded" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;" edge="1" parent="1" source="sReady" target="sHarvested"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se6" value="archive crop" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;" edge="1" parent="1" source="sHarvested" target="end"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se7" value="weather / disease / manual stop" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;dashed=1;" edge="1" parent="1" source="sPlanted" target="sFailed"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se8" value="critical issue" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;dashed=1;" edge="1" parent="1" source="sGrowing" target="sFailed"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="se9" value="crop loss before harvest" style="endArrow=block;html=1;rounded=0;strokeWidth=1.5;dashed=1;" edge="1" parent="1" source="sReady" target="sFailed"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
