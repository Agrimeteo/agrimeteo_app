        <mxCell id="cm7" value="7. Return current conditions / forecast" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="cp6" target="cp3"><mxGeometry relative="1" as="geometry"><mxPoint x="630" y="630" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="cm8" value="8. Request agronomic recommendations" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="cp3" target="cp7"><mxGeometry relative="1" as="geometry"><mxPoint x="1745" y="710" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="cm9" value="9. Return advice and risk factors" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="cp7" target="cp3"><mxGeometry relative="1" as="geometry"><mxPoint x="630" y="780" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="cm10" value="10. Create reminder notifications" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="cp3" target="cp8"><mxGeometry relative="1" as="geometry"><mxPoint x="2015" y="860" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="cm11" value="11. Return crop, plan, weather and recommendations" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="cp3" target="cp2"><mxGeometry relative="1" as="geometry"><mxPoint x="370" y="960" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="cm12" value="12. Render dashboard cards and timeline" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="cp2" target="cp1"><mxGeometry relative="1" as="geometry"><mxPoint x="120" y="1040" as="targetPoint" /></mxGeometry></mxCell>
