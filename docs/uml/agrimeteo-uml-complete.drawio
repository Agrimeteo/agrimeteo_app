        <mxCell id="p4" value="Express API" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="930" y="90" width="140" height="50" as="geometry" /></mxCell>
        <mxCell id="p5" value="Profiles Table" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1210" y="90" width="150" height="50" as="geometry" /></mxCell>
        <mxCell id="l1" style="shape=line;strokeWidth=1;dashed=1;" vertex="1" parent="1"><mxGeometry x="140" y="160" width="1" height="1180" as="geometry" /></mxCell>
        <mxCell id="l2" style="shape=line;strokeWidth=1;dashed=1;" vertex="1" parent="1"><mxGeometry x="410" y="160" width="1" height="1180" as="geometry" /></mxCell>
        <mxCell id="l3" style="shape=line;strokeWidth=1;dashed=1;" vertex="1" parent="1"><mxGeometry x="705" y="160" width="1" height="1180" as="geometry" /></mxCell>
        <mxCell id="l4" style="shape=line;strokeWidth=1;dashed=1;" vertex="1" parent="1"><mxGeometry x="1000" y="160" width="1" height="1180" as="geometry" /></mxCell>
        <mxCell id="l5" style="shape=line;strokeWidth=1;dashed=1;" vertex="1" parent="1"><mxGeometry x="1285" y="160" width="1" height="1180" as="geometry" /></mxCell>
        <mxCell id="m1" value="1. Submit email / password or Google login" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="p1" target="p2"><mxGeometry relative="1" as="geometry"><mxPoint x="410" y="220" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m2" value="2. signIn / signUp" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="p2" target="p3"><mxGeometry relative="1" as="geometry"><mxPoint x="705" y="280" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m3" value="3. Return session and user token" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="p3" target="p2"><mxGeometry relative="1" as="geometry"><mxPoint x="410" y="340" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m4" value="4. setSession / persist auth state" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="p2" target="p2"><mxGeometry relative="1" as="geometry"><mxPoint x="520" y="400" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m5" value="5. POST /api/v1/profile/sync" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="p2" target="p4"><mxGeometry relative="1" as="geometry"><mxPoint x="1000" y="470" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m6" value="6. Validate bearer token with Supabase" style="endArrow=block;html=1;rounded=0;dashed=1;" edge="1" parent="1" source="p4" target="p3"><mxGeometry relative="1" as="geometry"><mxPoint x="705" y="540" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m7" value="7. Upsert profile row and role data" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="p4" target="p5"><mxGeometry relative="1" as="geometry"><mxPoint x="1285" y="620" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m8" value="8. Return synced profile" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="p5" target="p4"><mxGeometry relative="1" as="geometry"><mxPoint x="1000" y="690" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m9" value="9. GET /api/v1/settings" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="p2" target="p4"><mxGeometry relative="1" as="geometry"><mxPoint x="1000" y="780" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m10" value="10. Read user settings + permissions" style="endArrow=block;html=1;rounded=0;dashed=1;" edge="1" parent="1" source="p4" target="p5"><mxGeometry relative="1" as="geometry"><mxPoint x="1285" y="850" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m11" value="11. Return hydrated session context" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="p4" target="p2"><mxGeometry relative="1" as="geometry"><mxPoint x="410" y="940" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="m12" value="12. Render app with theme, role and profile" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="p2" target="p1"><mxGeometry relative="1" as="geometry"><mxPoint x="140" y="1020" as="targetPoint" /></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
